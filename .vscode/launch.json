{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Uno Desktop Debug",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-uno-desktop",
      "program": "${workspaceFolder}/samples/DesktopFlyouts.Uno.Sample.App/bin/Debug/net10.0-desktop/DesktopFlyouts.Uno.Sample.App.dll",
      "args": [],
      "launchSettingsProfile": "DesktopFlyouts.Uno.Sample.App (Desktop)",
      "env": {
        "DOTNET_MODIFIABLE_ASSEMBLIES": "debug"
      },
      "cwd": "${workspaceFolder}/samples/DesktopFlyouts.Uno.Sample.App",
      "console": "internalConsole",
      "stopAtEntry": false,
      "sourceFileMap": {
          "/_/": "${workspaceFolder}/"
      }
    }
  ]
}
