<UserControl
    x:Class="DesktopFlyouts.RootView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DesktopFlyouts"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wctcontrols="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <local:RootViewModel x:Name="ViewModel" />
    </UserControl.DataContext>

    <ScrollViewer>
        <StackPanel Padding="36" Spacing="24">

            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Tray icon sample" />

            <StackPanel Spacing="4">
                <TextBlock
                    Margin="4,0"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Tray settings" />
                <wctcontrols:SettingsCard Header="Icon path">
                    <TextBox
                        Width="300"
                        PlaceholderText="Enter path to the icon"
                        Text="{x:Bind ViewModel.IconPath, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Tooltip">
                    <TextBox
                        Width="300"
                        PlaceholderText="Enter the tooltip text"
                        Text="{x:Bind ViewModel.TooltipText, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock
                    Margin="4,0"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Flyout settings" />
                <wctcontrols:SettingsCard Header="Flyout example">
                    <ComboBox
                        Width="150"
                        ItemsSource="{x:Bind ViewModel.FlyoutExamples.Values}"
                        SelectedIndex="{x:Bind ViewModel.SelectedFlyoutExampleIndex, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Flyout state">
                    <Button
                        Width="150"
                        Command="{x:Bind ViewModel.ToggleFlyoutOpenCommand}"
                        Content="Toggle open" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Popup direction">
                    <ComboBox
                        Width="150"
                        IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.PopupDirections.Values}"
                        SelectedIndex="{x:Bind ViewModel.SelectedPopupDirectionIndex, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Enable backdrop">
                    <ToggleSwitch IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}" IsOn="{x:Bind ViewModel.IsBackdropEnabled, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Placement">
                    <ComboBox
                        Width="150"
                        IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.FlyoutPlacements.Values}"
                        SelectedIndex="{x:Bind ViewModel.SelectedFlyoutPlacementIndex, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Flyout width">
                    <NumberBox
                        x:Name="FlyoutWidthNumberBox"
                        Width="150"
                        IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                        Minimum="0"
                        PlaceholderText="Auto"
                        SmallChange="16"
                        SpinButtonPlacementMode="Inline"
                        Value="{x:Bind ViewModel.FlyoutWidthValue, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Flyout height">
                    <NumberBox
                        x:Name="FlyoutHeightNumberBox"
                        Width="150"
                        IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                        Minimum="0"
                        PlaceholderText="Auto"
                        SmallChange="16"
                        SpinButtonPlacementMode="Inline"
                        Value="{x:Bind ViewModel.FlyoutHeightValue, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Hide on losing focus">
                    <ToggleSwitch IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}" IsOn="{x:Bind ViewModel.HideOnLostFocus, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Swipe to dismiss">
                    <ToggleSwitch IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}" IsOn="{x:Bind ViewModel.IsSwipeToDismissEnabled, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Swipe dismiss threshold">
                    <NumberBox
                        x:Name="SwipeDismissThresholdNumberBox"
                        Width="150"
                        IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                        Minimum="1"
                        SmallChange="8"
                        SpinButtonPlacementMode="Inline"
                        Value="{x:Bind ViewModel.SwipeDismissThresholdValue, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Activation mode">
                    <ComboBox
                        Width="150"
                        IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.ActivationModes.Values}"
                        SelectedIndex="{x:Bind ViewModel.SelectedActivationModeIndex, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="Auto close delay">
                    <NumberBox
                        x:Name="AutoCloseDelayNumberBox"
                        Width="150"
                        IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                        Minimum="0"
                        PlaceholderText="Off"
                        SmallChange="0.5"
                        SpinButtonPlacementMode="Inline"
                        Value="{x:Bind ViewModel.AutoCloseDelaySecondsValue, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
                <wctcontrols:SettingsCard Header="System backdrop">
                    <ComboBox
                        Width="150"
                        IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.SystemBackdrops.Values}"
                        SelectedIndex="{x:Bind ViewModel.SelectedSystemBackdropIndex, Mode=TwoWay}" />
                </wctcontrols:SettingsCard>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
