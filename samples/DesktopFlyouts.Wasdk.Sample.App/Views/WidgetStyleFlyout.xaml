<local:DesktopFlyout
    x:Class="DesktopFlyouts.WidgetStyleFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DesktopFlyouts"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    FlyoutWidth="1000"
    Placement="BottomLeft"
    PopupDirection="Horizontal"
    mc:Ignorable="d">

    <local:DesktopFlyout.Islands>
        <local:DesktopFlyoutIsland IslandHeight="*">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="24,18">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="May 5" />
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Good evening" />
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <CommandBar DefaultLabelPosition="Right" IsDynamicOverflowEnabled="False">
                            <AppBarButton Icon="Setting" Label="Settings" />
                        </CommandBar>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1">
                    <Grid
                        Margin="24,0,24,24"
                        VerticalAlignment="Top"
                        ColumnSpacing="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="12">
                            <Border
                                Width="100"
                                Height="20"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{StaticResource OverlayCornerRadius}" />
                            <Border
                                Height="150"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{StaticResource OverlayCornerRadius}" />
                            <Border
                                Height="400"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{StaticResource OverlayCornerRadius}" />
                            <Border
                                Height="250"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{StaticResource OverlayCornerRadius}" />
                            <Border
                                Width="100"
                                Height="20"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Left"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{StaticResource OverlayCornerRadius}" />
                            <Border
                                Height="300"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{StaticResource OverlayCornerRadius}" />
                            <Border
                                Height="200"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{StaticResource OverlayCornerRadius}" />
                            <Border
                                Height="135"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{StaticResource OverlayCornerRadius}" />
                        </StackPanel>

                        <Grid Grid.Column="1" ColumnSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <SelectorBar x:Name="SelectorBar1">
                                <SelectorBarItem
                                    x:Name="SelectorBarItemRecent"
                                    Icon="Favorite"
                                    Text="Top" />
                                <SelectorBarItem
                                    x:Name="SelectorBarItemShared"
                                    Icon="Accept"
                                    Text="Watch" />
                                <SelectorBarItem
                                    x:Name="SelectorBarItemFavorites"
                                    Icon="Video"
                                    Text="Play" />
                            </SelectorBar>

                            <StackPanel Grid.Row="1" Spacing="12">
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Spacing="12">
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                                <Border
                                    Height="300"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </local:DesktopFlyoutIsland>
    </local:DesktopFlyout.Islands>

</local:DesktopFlyout>
