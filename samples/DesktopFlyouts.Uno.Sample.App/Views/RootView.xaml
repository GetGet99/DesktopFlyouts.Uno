<UserControl
    x:Class="DesktopFlyouts.RootView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DesktopFlyouts"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <local:RootViewModel x:Name="ViewModel" />
    </UserControl.DataContext>

    <ScrollViewer>
        <StackPanel Padding="36" Spacing="24">

            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Tray icon sample" />

            <StackPanel Spacing="4">
                <TextBlock
                    Margin="4,0"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Tray settings" />

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Icon path" />
                        <TextBox
                            Grid.Column="1"
                            Width="300"
                            HorizontalAlignment="Left"
                            PlaceholderText="Enter path to the icon"
                            Text="{x:Bind ViewModel.IconPath, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Tooltip" />
                        <TextBox
                            Grid.Column="1"
                            Width="300"
                            HorizontalAlignment="Left"
                            PlaceholderText="Enter the tooltip text"
                            Text="{x:Bind ViewModel.TooltipText, Mode=TwoWay}" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock
                    Margin="4,0"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="Flyout settings" />

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Flyout example" />
                        <ComboBox
                            Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Left"
                            ItemsSource="{x:Bind ViewModel.FlyoutExamples.Values}"
                            SelectedIndex="{x:Bind ViewModel.SelectedFlyoutExampleIndex, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Flyout state" />
                        <Button
                            Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Left"
                            Command="{x:Bind ViewModel.ToggleFlyoutOpenCommand}"
                            Content="Toggle open" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Popup direction" />
                        <ComboBox
                            Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.PopupDirections.Values}"
                            SelectedIndex="{x:Bind ViewModel.SelectedPopupDirectionIndex, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Enable backdrop" />
                        <ToggleSwitch
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            IsOn="{x:Bind ViewModel.IsBackdropEnabled, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Placement" />
                        <ComboBox
                            Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.FlyoutPlacements.Values}"
                            SelectedIndex="{x:Bind ViewModel.SelectedFlyoutPlacementIndex, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Flyout width" />
                        <NumberBox
                            Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            Minimum="0"
                            PlaceholderText="Auto"
                            SmallChange="16"
                            SpinButtonPlacementMode="Inline"
                            Value="{x:Bind ViewModel.FlyoutWidthValue, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Flyout height" />
                        <NumberBox
                            Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            Minimum="0"
                            PlaceholderText="Auto"
                            SmallChange="16"
                            SpinButtonPlacementMode="Inline"
                            Value="{x:Bind ViewModel.FlyoutHeightValue, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Hide on lost focus" />
                        <ToggleSwitch
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            IsOn="{x:Bind ViewModel.HideOnLostFocus, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Swipe to dismiss" />
                        <ToggleSwitch
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            IsOn="{x:Bind ViewModel.IsSwipeToDismissEnabled, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Activation mode" />
                        <ComboBox
                            Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.ActivationModes.Values}"
                            SelectedIndex="{x:Bind ViewModel.SelectedActivationModeIndex, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="Auto close delay" />
                        <NumberBox
                            Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            Minimum="0"
                            PlaceholderText="Off"
                            SmallChange="0.5"
                            SpinButtonPlacementMode="Inline"
                            Value="{x:Bind ViewModel.AutoCloseDelaySecondsValue, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <Border
                    Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="System backdrop" />
                        <ComboBox
                            Grid.Column="1"
                            Width="150"
                            HorizontalAlignment="Left"
                            IsEnabled="{x:Bind ViewModel.IsModifiable, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.SystemBackdrops.Values}"
                            SelectedIndex="{x:Bind ViewModel.SelectedSystemBackdropIndex, Mode=TwoWay}" />
                    </Grid>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
