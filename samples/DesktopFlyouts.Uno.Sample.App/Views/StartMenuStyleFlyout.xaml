<local:DesktopFlyout
    x:Class="DesktopFlyouts.StartMenuStyleFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DesktopFlyouts"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    FlyoutHeight="725"
    IslandsOrientation="Horizontal"
    Placement="BottomCenter"
    mc:Ignorable="d">

    <local:DesktopFlyout.Islands>
        <local:DesktopFlyoutIsland IslandWidth="640">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Background="{ThemeResource FlyoutOverlayBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>
                    <Border
                        Height="28"
                        Margin="36"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                    <Border
                        Grid.Row="1"
                        Width="60"
                        Height="18"
                        Margin="64,8,64,20"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                    <Border
                        Grid.Row="1"
                        Width="60"
                        Height="18"
                        Margin="64,8,64,20"
                        HorizontalAlignment="Right"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                    <Grid
                        Grid.Row="2"
                        Margin="36,0"
                        ColumnSpacing="16"
                        RowSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="8">
                            <Border Width="36" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                            <Border Width="60" Height="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="8">
                            <Border Width="36" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                            <Border Width="60" Height="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="8">
                            <Border Width="36" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                            <Border Width="60" Height="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="8">
                            <Border Width="36" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                            <Border Width="60" Height="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Spacing="8">
                            <Border Width="36" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                            <Border Width="60" Height="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="5" Spacing="8">
                            <Border Width="36" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                            <Border Width="60" Height="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                        </StackPanel>
                    </Grid>
                    <Border
                        Grid.Row="3"
                        Width="60"
                        Height="18"
                        Margin="64,0,64,20"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                    <Border
                        Grid.Row="3"
                        Width="60"
                        Height="18"
                        Margin="64,0,64,20"
                        HorizontalAlignment="Right"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                    <Grid
                        Grid.Row="4"
                        Margin="36,0,36,36"
                        ColumnSpacing="16"
                        RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <Border Width="36" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                            <Border Width="180" Height="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Border Width="36" Height="36" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                            <Border Width="180" Height="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" />
                        </StackPanel>
                    </Grid>
                </Grid>
                <Grid
                    Grid.Row="1"
                    Height="64"
                    Padding="64,0"
                    BorderBrush="{ThemeResource FlyoutSeparatorSecondaryBackgroundBrush}"
                    BorderThickness="0,1,0,0">
                    <Border
                        Width="180"
                        Height="18"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                    <Border
                        Width="24"
                        Height="24"
                        HorizontalAlignment="Right"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                </Grid>
            </Grid>
        </local:DesktopFlyoutIsland>

        <local:DesktopFlyoutIsland IslandWidth="210">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid
                    Padding="32"
                    Background="{ThemeResource FlyoutOverlayBackgroundBrush}"
                    RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="8">
                        <Border
                            Width="36"
                            Height="64"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="4" />
                        <Border
                            Width="64"
                            Height="18"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="4" />
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="12">
                            <Border
                                Width="20"
                                Height="20"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="4" />
                            <Border
                                Width="20"
                                Height="20"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="4" />
                            <Border
                                Width="36"
                                Height="20"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="4" />
                        </StackPanel>
                    </StackPanel>

                    <Border
                        Grid.Row="3"
                        Width="60"
                        Height="18"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                </Grid>

                <Grid
                    Grid.Row="1"
                    Height="64"
                    Padding="16,0"
                    BorderBrush="{ThemeResource FlyoutSeparatorSecondaryBackgroundBrush}"
                    BorderThickness="0,1,0,0"
                    ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="130"
                        Height="32"
                        HorizontalAlignment="Left"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                    <Border
                        Grid.Column="1"
                        Width="36"
                        Height="32"
                        HorizontalAlignment="Right"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4" />
                </Grid>
            </Grid>
        </local:DesktopFlyoutIsland>
    </local:DesktopFlyout.Islands>

</local:DesktopFlyout>
