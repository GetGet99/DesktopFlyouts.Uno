<local:TrayIconFlyout
    x:Class="U5BFA.Libraries.ButtonFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:U5BFA.Libraries"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="360"
    ActivationMode="NoActivateOnOpen"
    HideOnLostFocus="False"
    IsSwipeToDismissEnabled="True"
    IslandsOrientation="Vertical"
    Placement="BottomRight"
    PopupDirection="RightToLeft"
    PressedScale="0.9"
    mc:Ignorable="d">

    <local:TrayIconFlyoutIsland>
        <!--<TextBlock Margin="32,16" Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit..." />-->
        <Grid Padding="16,16,16,24" RowSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="18"
                    Height="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                <Border
                    Grid.Column="1"
                    Width="100"
                    Height="18"
                    HorizontalAlignment="Left"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                <Border
                    Grid.Column="2"
                    Width="18"
                    Height="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                <Border
                    Grid.Column="3"
                    Width="18"
                    Height="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="{StaticResource OverlayCornerRadius}" />
            </Grid>
            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.RowSpan="2"
                    Width="44"
                    Height="44"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="20" />
                <Border
                    Grid.Column="1"
                    Width="100"
                    Height="18"
                    HorizontalAlignment="Left"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="{StaticResource OverlayCornerRadius}" />
                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="230"
                    Height="18"
                    HorizontalAlignment="Left"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="{StaticResource OverlayCornerRadius}" />
            </Grid>
        </Grid>
    </local:TrayIconFlyoutIsland>

</local:TrayIconFlyout>
